    "./6809.js": "./src/6809.js",
    "./65816": "./src/65816.js",
    "./65816.js": "./src/65816.js",
    "./z80": "./src/z80.js",
    "./z80.js": "./src/z80.js"
  },
  "scripts": {
    "test": "c8 qunit && c8 report --reporter=html",
